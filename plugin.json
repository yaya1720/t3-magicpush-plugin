{
    "plugin_id": "automation.magicpush",
    "plugin_name": "魔法推送通知",
    "plugin_version": "1.0.0",
    "plugin_type": "automation",
    "description": "任务完成后通过魔法推送发送通知",
    "author": "你的GitHub用户名",
    "config_schema": {
        "type": "object",
        "properties": {
            "url": {
                "type": "string",
                "title": "Webhook 地址",
                "description": "魔法推送的接口地址，例如 http://192.168.1.3:15014/api/push/",
                "format": "uri"
            },
            "token": {
                "type": "string",
                "title": "认证令牌",
                "description": "你的魔法推送令牌",
                "format": "password"
            },
            "enabled_events": {
                "type": "string",
                "title": "启用事件列表",
                "description": "触发通知的事件，多个用逗号分隔",
                "default": "task.completed,task.failed"
            }
        },
        "required": ["url", "token"]
    }
}